# Production database
DATABASE_URL="postgresql://spacefly:change-me@db.example.com:5432/spacefly?sslmode=require"

# Authentication
JWT_SECRET="replace-with-a-long-random-secret"
JWT_REFRESH_SECRET="replace-with-a-different-long-random-secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
BCRYPT_ROUNDS=12
CORS_ORIGINS="https://spacefly.ai,https://admin.spacefly.ai"

# Kafka
KAFKA_BROKERS="kafka:9092"
KAFKA_ENABLED=true

# Email
RESEND_API_KEY="re_replace_with_production_key"
RESEND_FROM_EMAIL="noreply@spacefly.ai"

# Public frontend build/runtime URLs
NEXT_PUBLIC_AUTH_SERVICE_URL="https://api.spacefly.ai"
NEXT_PUBLIC_PRODUCT_SERVICE_URL="https://api.spacefly.ai"
NEXT_PUBLIC_ORDER_SERVICE_URL="https://api.spacefly.ai"
NEXT_PUBLIC_ADMIN_URL="https://admin.spacefly.ai"
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="replace-with-cloudinary-cloud-name"

# Caddy/HTTPS
CADDY_EMAIL="admin@spacefly.ai"

# Ingress mode
# Use nginx on a shared VPS where Nginx already owns ports 80/443.
# Use caddy only with docker-compose.caddy.yml on a dedicated VPS where this stack can bind 80/443.
INGRESS_MODE="nginx"
