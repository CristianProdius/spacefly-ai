# Production database
POSTGRES_DB="spacefly"
POSTGRES_USER="spacefly"
POSTGRES_PASSWORD="replace-with-a-long-random-postgres-password"
DATABASE_URL="postgresql://spacefly:replace-with-a-long-random-postgres-password@postgres:5432/spacefly?schema=public"

# Authentication
JWT_SECRET="replace-with-a-long-random-secret"
JWT_REFRESH_SECRET="replace-with-a-different-long-random-secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
BCRYPT_ROUNDS=12
CORS_ORIGINS="https://spacefly.ai,https://admin.spacefly.ai"

# Kafka
KAFKA_BROKERS="kafka:9092"
KAFKA_ENABLED=true

# Email
RESEND_API_KEY="re_replace_with_production_key"
RESEND_FROM_EMAIL="cristian@prodiusenterprise.com"

# MinIO / S3-compatible uploads
MINIO_ROOT_USER="spacefly"
MINIO_ROOT_PASSWORD="replace-with-a-long-random-minio-root-password"
S3_ENDPOINT="http://minio:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID="spacefly"
S3_SECRET_ACCESS_KEY="replace-with-a-long-random-minio-root-password"
S3_BUCKET="spacefly-uploads"
S3_PUBLIC_BASE_URL="https://api.spacefly.ai/uploads"
S3_FORCE_PATH_STYLE=true

# Public frontend build/runtime URLs
NEXT_PUBLIC_AUTH_SERVICE_URL="https://api.spacefly.ai"
NEXT_PUBLIC_PRODUCT_SERVICE_URL="https://api.spacefly.ai"
NEXT_PUBLIC_ORDER_SERVICE_URL="https://api.spacefly.ai"
NEXT_PUBLIC_ADMIN_URL="https://admin.spacefly.ai"

# Caddy/HTTPS
CADDY_EMAIL="admin@spacefly.ai"

# Ingress mode
# Use nginx on a shared VPS where Nginx already owns ports 80/443.
# Use caddy only with docker-compose.caddy.yml on a dedicated VPS where this stack can bind 80/443.
INGRESS_MODE="nginx"
